import React, { useState } from 'react'
import type { DevCardType } from '../../../server/src/game-logic'

const DEV_CARD_LABELS: Record<DevCardType, string> = {
  knight: '🎖️ 骑士',
  victory_point: '🏆 分数',
  road_building: '🛣️ 道路建设',
  monopoly: '🎁 资源垄断',
  year_of_plenty: '🎲 资源丰收',
}

const DEV_CARD_COLORS: Record<DevCardType, string> = {
  knight: '#e74c3c',
  victory_point: '#f39c12',
  road_building: '#8e44ad',
  monopoly: '#16a085',
  year_of_plenty: '#2980b9',
}

interface Props {
  onSelect: (cardType: DevCardType) => void
  onClose: () => void
  remainingCards: DevCardType[]
}

export default function DevCardDeck({ onSelect, onClose, remainingCards }: Props) {
  const [selectedIndex, setSelectedIndex] = useState<number | null>(null)
  const [isFlipping, setIsFlipping] = useState(false)

  const handleCardClick = (index: number) => {
    if (isFlipping || selectedIndex !== null) return
    
    setSelectedIndex(index)
    setIsFlipping(true)
    
    // 翻转动画 600ms，然后等待 800ms 让玩家看清卡面
    setTimeout(() => {
      const cardType = remainingCards[index]
      onSelect(cardType)
      setTimeout(() => {
        onClose()
      }, 800)
    }, 600)
  }

  return (
    <div style={{
      position: 'fixed',
      top: 0,
      left: 0,
      right: 0,
      bottom: 0,
      background: 'rgba(0,0,0,0.85)',
      display: 'flex',
      flexDirection: 'column',
      alignItems: 'center',
      justifyContent: 'center',
      zIndex: 9999,
      padding: 20,
    }}>
      
      <div style={{
        color: '#fff',
        fontSize: 24,
        fontWeight: 'bold',
        marginBottom: 30,
        textAlign: 'center',
      }}>
        📜 选择一张发展卡 ({remainingCards.length}/25)
      </div>

      <div style={{
        display: 'grid',
        gridTemplateColumns: 'repeat(auto-fit, minmax(80px, 1fr))',
        gap: 15,
        maxWidth: 900,
        width: '100%',
      }}>
        {remainingCards.map((cardType, index) => {
          const isSelected = selectedIndex === index
          const isFlipped = isSelected && isFlipping

          return (
            <div
              key={index}
              onClick={() => handleCardClick(index)}
              style={{
                width: 80,
                height: 120,
                perspective: 1000,
                cursor: isFlipping ? 'default' : 'pointer',
                margin: '0 auto',
              }}
            >
              <div style={{
                width: '100%',
                height: '100%',
                position: 'relative',
                transformStyle: 'preserve-3d',
                transition: 'transform 0.6s',
                transform: isFlipped ? 'rotateY(180deg)' : 'rotateY(0deg)',
              }}>
                
                {/* 卡背 */}
                <div style={{
                  position: 'absolute',
                  width: '100%',
                  height: '100%',
                  backfaceVisibility: 'hidden',
                  background: 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
                  borderRadius: 8,
                  border: '3px solid #fff',
                  display: 'flex',
                  alignItems: 'center',
                  justifyContent: 'center',
                  fontSize: 32,
                  boxShadow: '0 4px 12px rgba(0,0,0,0.4)',
                  transition: 'transform 0.2s',
                  transform: isSelected ? 'scale(1.05)' : 'scale(1)',
                }}>
                  🎴
                </div>

                {/* 卡面 */}
                <div style={{
                  position: 'absolute',
                  width: '100%',
                  height: '100%',
                  backfaceVisibility: 'hidden',
                  background: DEV_CARD_COLORS[cardType],
                  borderRadius: 8,
                  border: '3px solid #ffd700',
                  display: 'flex',
                  flexDirection: 'column',
                  alignItems: 'center',
                  justifyContent: 'center',
                  padding: 8,
                  boxShadow: '0 8px 20px rgba(255,215,0,0.6)',
                  transform: 'rotateY(180deg)',
                }}>
                  <div style={{
                    fontSize: 28,
                    marginBottom: 4,
                  }}>
                    {DEV_CARD_LABELS[cardType].split(' ')[0]}
                  </div>
                  <div style={{
                    fontSize: 10,
                    color: '#fff',
                    textAlign: 'center',
                    fontWeight: 'bold',
                    textShadow: '0 1px 2px rgba(0,0,0,0.5)',
                  }}>
                    {DEV_CARD_LABELS[cardType].split(' ')[1]}
                  </div>
                </div>

              </div>
            </div>
          )
        })}
      </div>

      {!isFlipping && (
        <button
          onClick={onClose}
          style={{
            marginTop: 30,
            padding: '12px 30px',
            fontSize: 16,
            background: '#e74c3c',
            color: '#fff',
            border: 'none',
            borderRadius: 8,
            cursor: 'pointer',
            fontWeight: 'bold',
          }}
        >
          取消
        </button>
      )}

    </div>
  )
}
